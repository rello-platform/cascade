{
  "name": "@rello-platform/cascade",
  "version": "0.1.2",
  "description": "Push/mirror primitives for cascading settings across Rello Platform spokes.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/**/*.test.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rello-platform/cascade.git"
  },
  "homepage": "https://github.com/rello-platform/cascade",
  "license": "UNLICENSED",
  "private": false,
  "devDependencies": {
    "@types/node": "^22.19.18",
    "typescript": "^5.6.3"
  }
}
